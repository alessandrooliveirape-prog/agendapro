# Email (para lembretes e verificação)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=agendapro1007@agendapro1007.com.br
SMTP_PASS=sua_senha_de_app_aqui

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
